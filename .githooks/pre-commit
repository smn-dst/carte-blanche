#!/bin/sh

# =============================================================================
# Hook pre-commit : vérifie la qualité du code AVANT chaque commit
# Retourne 0 = OK, autre = bloque le commit
# =============================================================================

# Couleurs pour les messages
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "=========================================="
echo "  🔍 Vérifications pre-commit en cours..."
echo "=========================================="
echo ""

# Récupérer uniquement les fichiers PHP staged (pas tout le projet)
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$')
STAGED_TWIG_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.twig$')

HAS_ERRORS=0

# -----------------------------------------------------------------------------
# 1. Vérifier qu'il n'y a pas de dump(), dd(), var_dump() dans le code PHP
# -----------------------------------------------------------------------------
if [ -n "$STAGED_PHP_FILES" ]; then
    echo "${YELLOW}[1/4] Recherche de debug oublié (PHP)...${NC}"

    for FILE in $STAGED_PHP_FILES; do
        # Vérifier dans le contenu staged (pas le fichier sur disque)
        DUMP_FOUND=$(git diff --cached -- "$FILE" | grep -E '^\+.*\b(dump|dd|var_dump|print_r|die|exit)\s*\(' | grep -v '^\+\+\+')

        if [ -n "$DUMP_FOUND" ]; then
            echo "${RED}  ✗ Debug trouvé dans $FILE :${NC}"
            echo "$DUMP_FOUND"
            HAS_ERRORS=1
        fi
    done

    if [ $HAS_ERRORS -eq 0 ]; then
        echo "${GREEN}  ✓ Aucun debug oublié${NC}"
    fi
fi

# -----------------------------------------------------------------------------
# 2. Vérifier qu'il n'y a pas de console.log() dans le JS/Twig
# -----------------------------------------------------------------------------
ALL_FRONT_FILES="$STAGED_JS_FILES $STAGED_TWIG_FILES"
if [ -n "$(echo "$ALL_FRONT_FILES" | tr -d '[:space:]')" ]; then
    echo "${YELLOW}[2/4] Recherche de console.log oublié (JS/Twig)...${NC}"

    for FILE in $ALL_FRONT_FILES; do
        [ -z "$FILE" ] && continue
        CONSOLE_FOUND=$(git diff --cached -- "$FILE" | grep -E '^\+.*console\.(log|debug|warn|error|info)\s*\(' | grep -v '^\+\+\+')

        if [ -n "$CONSOLE_FOUND" ]; then
            echo "${RED}  ✗ console.log trouvé dans $FILE :${NC}"
            echo "$CONSOLE_FOUND"
            HAS_ERRORS=1
        fi
    done

    if [ $HAS_ERRORS -eq 0 ]; then
        echo "${GREEN}  ✓ Aucun console.log oublié${NC}"
    fi
else
    echo "${YELLOW}[2/4] Pas de fichiers JS/Twig modifiés, skip.${NC}"
fi

# -----------------------------------------------------------------------------
# 3. PHP-CS-Fixer (style du code PHP) - uniquement sur les fichiers staged
# -----------------------------------------------------------------------------
if [ -n "$STAGED_PHP_FILES" ]; then
    echo "${YELLOW}[3/4] Vérification du style PHP (PHP-CS-Fixer)...${NC}"

    # Adapter le chemin selon l'installation
    if [ -f "./php-cs-fixer.phar" ]; then
        CS_FIXER="php ./php-cs-fixer.phar"
    elif [ -f "./vendor/bin/php-cs-fixer" ]; then
        CS_FIXER="./vendor/bin/php-cs-fixer"
    else
        echo "${YELLOW}  ⚠ PHP-CS-Fixer non trouvé, skip.${NC}"
        CS_FIXER=""
    fi

    if [ -n "$CS_FIXER" ]; then
        # Exclure les fichiers générés (assets/vendor, etc.)
        CS_FIXER_FILES=""
        for F in $STAGED_PHP_FILES; do
            case "$F" in
                assets/vendor/*) ;;
                *) CS_FIXER_FILES="$CS_FIXER_FILES $F" ;;
            esac
        done
        # Lancer sur les fichiers staged (hors exclus)
        FIXER_OUTPUT=""
        for FILE in $CS_FIXER_FILES; do
            [ -z "$FILE" ] && continue
            RESULT=$($CS_FIXER fix "$FILE" --dry-run --diff 2>&1)
            if [ $? -ne 0 ]; then
                FIXER_OUTPUT="${FIXER_OUTPUT}\n${RESULT}"
                HAS_ERRORS=1
            fi
        done

        if [ -n "$FIXER_OUTPUT" ]; then
            echo "${RED}  ✗ Erreurs de style détectées !${NC}"
            echo "$FIXER_OUTPUT"
            echo ""
            echo "${YELLOW}  💡 Pour corriger automatiquement : $CS_FIXER fix${NC}"
        else
            echo "${GREEN}  ✓ Style PHP OK${NC}"
        fi
    fi
else
    echo "${YELLOW}[3/4] Pas de fichiers PHP modifiés, skip.${NC}"
fi

# -----------------------------------------------------------------------------
# 4. PHPStan (analyse statique) - uniquement sur les fichiers staged
#    Préfère Docker (PHP 8.4) pour éviter l'erreur de version PHP locale
# -----------------------------------------------------------------------------
if [ -n "$STAGED_PHP_FILES" ]; then
    echo "${YELLOW}[4/4] Analyse statique PHPStan...${NC}"

    # Préférer PHPStan via Docker (même PHP que le projet) si disponible
    if command -v docker >/dev/null 2>&1 && docker compose exec -T php true 2>/dev/null; then
        PHPSTAN="docker compose exec -T php php vendor/bin/phpstan"
    elif [ -f "./vendor/bin/phpstan" ]; then
        PHPSTAN="./vendor/bin/phpstan"
    else
        echo "${YELLOW}  ⚠ PHPStan non trouvé (Docker non dispo ou vendor), skip.${NC}"
        PHPSTAN=""
    fi

    if [ -n "$PHPSTAN" ]; then
        # Ne passer que les fichiers dans src/ ou tests/ (exclut les configs type .php-cs-fixer.dist.php)
        PHPSTAN_FILES=""
        for F in $STAGED_PHP_FILES; do
            case "$F" in
                src/*|tests/*) PHPSTAN_FILES="$PHPSTAN_FILES $F" ;;
            esac
        done
        if [ -n "$(echo "$PHPSTAN_FILES" | tr -d '[:space:]')" ]; then
            $PHPSTAN analyse --memory-limit=512M --no-progress $PHPSTAN_FILES 2>&1
            if [ $? -ne 0 ]; then
                echo "${RED}  ✗ Erreurs PHPStan détectées !${NC}"
                HAS_ERRORS=1
            else
                echo "${GREEN}  ✓ Analyse statique OK${NC}"
            fi
        else
            echo "${GREEN}  ✓ Aucun fichier PHP dans src/ ou tests/, skip PHPStan${NC}"
        fi
    fi
else
    echo "${YELLOW}[4/4] Pas de fichiers PHP modifiés, skip.${NC}"
fi

# -----------------------------------------------------------------------------
# Résultat final
# -----------------------------------------------------------------------------
echo ""
if [ $HAS_ERRORS -ne 0 ]; then
    echo "=========================================="
    echo "${RED}  ✗ COMMIT BLOQUÉ - Corrige les erreurs ci-dessus${NC}"
    echo "=========================================="
    echo ""
    echo "${YELLOW}  Pour bypass en urgence : git commit --no-verify${NC}"
    echo ""
    exit 1
fi

echo "=========================================="
echo "${GREEN}  ✓ Toutes les vérifications sont passées${NC}"
echo "=========================================="
echo ""
exit 0
