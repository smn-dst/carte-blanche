{% extends 'base.html.twig' %}

{% block title %}Mon panier — Carte Blanche
{% endblock %}

{% block body %}

	{% include 'Components/headers/page-header.html.twig' with {
		title: 'Mon panier',
		description: itemCount ~ ' place' ~ (itemCount > 1 ? 's' : '') ~ ' dans votre panier'
	} %}

	<div class="container mx-auto max-w-full px-4 py-8 overflow-x-hidden">

		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="mb-4 p-4 rounded-lg border {{ type == 'success' ? 'bg-green-900/20 border-green-500/30 text-green-400' : 'bg-red-900/20 border-red-500/30 text-red-400' }}">
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}

		{% if cart.cartItems is empty %}

			<div class="text-center py-20">
				<div class="w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 flex items-center justify-center">
					<svg class="size-10 text-primary" aria-hidden="true"><use href="#icon-shopping-cart"/></svg>
				</div>
				<h2 class="text-2xl font-bold text-foreground mb-2">Votre panier est vide</h2>
				<p class="text-muted-foreground mb-8">Parcourez les enchères disponibles pour réserver vos places.</p>
				<a href="{{ path('app_encheres') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors">
					Voir les enchères
				</a>
			</div>

		{% else %}

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 min-w-0">

				{# Liste des articles #}
				<div class="lg:col-span-2 space-y-4 min-w-0">
					{% for item in cart.cartItems %}
						{% set restaurant = item.restaurant %}
						{% set unitPrice = restaurant.ticketPrice|default(0) %}
						{% set lineTotal = unitPrice * item.quantity %}
						{% set remaining = restaurant.maxCapacity - restaurant.ticketsSold %}

						<div class="bg-(--card) border border-border rounded-lg min-w-0 max-w-full overflow-hidden">
							<div class="flex flex-col sm:flex-row sm:gap-6 sm:p-6 min-w-0">

								{# Image : pleine largeur sur mobile, vignette à gauche à partir de sm #}
								<a href="{{ path('app_enchere_detail', { id: restaurant.id }) }}" class="block w-full shrink-0 sm:w-28 sm:mx-0 overflow-hidden bg-neutral-900">
									{% if restaurant.images is not empty %}
										<img src="{{ asset('uploads/restaurants/' ~ restaurant.images|first.filename) }}" alt="{{ restaurant.name }}" class="w-full aspect-[16/9] sm:aspect-auto sm:h-28 sm:w-28 object-cover rounded-none sm:rounded-lg">
									{% else %}
										<div class="w-full aspect-[16/9] sm:aspect-auto sm:h-28 sm:w-28 flex items-center justify-center rounded-none sm:rounded-lg bg-gray-800">
											<span class="text-gray-600 text-xs">N/A</span>
										</div>
									{% endif %}
								</a>

								<div class="flex-1 min-w-0 w-full px-4 pb-4 pt-4 sm:p-0">
									{# Infos restaurant #}
									<div class="flex items-start justify-between gap-3 min-w-0">
										<div class="min-w-0 flex-1">
											{% if restaurant.categories is not empty %}
												<span class="text-[10px] text-primary uppercase tracking-wider font-semibold">
													{{ restaurant.categories|first.name }}
												</span>
											{% endif %}
											<h3 class="font-bold text-foreground text-base sm:text-lg break-words">
												<a href="{{ path('app_enchere_detail', { id: restaurant.id }) }}" class="hover:text-primary transition-colors">
													{{ restaurant.name }}
												</a>
											</h3>
											<p class="text-sm text-muted-foreground break-words">{{ restaurant.address }}</p>
										</div>

										{# Supprimer #}
										<form method="post" action="{{ path('app_cart_remove', { id: item.id }) }}" class="shrink-0" data-preserve-scroll>
											<input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.id) }}">
											<button type="submit" class="p-2 text-muted-foreground hover:text-red-400 transition-colors cursor-pointer" title="Retirer">
												<svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
													<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
												</svg>
											</button>
										</form>
									</div>

									{# Détails enchère #}
									<div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted-foreground break-words">
										{% if restaurant.auctionDate %}
											<span class="inline-flex items-center gap-1.5 min-w-0">
												<svg class="size-4 text-primary shrink-0" aria-hidden="true"><use href="#icon-calendar-range"/></svg>
												{{ restaurant.auctionDate|date('d/m/Y') }}</span>
										{% endif %}
										{% if restaurant.auctionTime %}
											<span class="inline-flex items-center gap-1.5 min-w-0">
												<svg class="size-4 text-primary shrink-0" aria-hidden="true"><use href="#icon-clock"/></svg>
												{{ restaurant.auctionTime|date('H:i') }}</span>
										{% endif %}
										{% if restaurant.auctionLocation %}
											<span class="inline-flex items-start gap-1.5 min-w-0 basis-full sm:basis-auto">
												<svg class="size-4 text-primary shrink-0 mt-0.5" aria-hidden="true"><use href="#icon-map"/></svg>
												{{ restaurant.auctionLocation }}</span>
										{% endif %}
										<span class="min-w-0">{{ remaining }}
											place{{ remaining > 1 ? 's' : '' }}
											restante{{ remaining > 1 ? 's' : '' }}</span>
									</div>

									{# Quantité + prix : colonne sur mobile pour éviter le débordement #}
									<div class="mt-4 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between min-w-0">
										<form method="post" action="{{ path('app_cart_update', { id: item.id }) }}" class="flex flex-wrap items-center gap-x-3 gap-y-2 min-w-0" data-preserve-scroll>
											<input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ item.id) }}">
											<label class="text-xs text-muted-foreground uppercase tracking-wider font-semibold w-full sm:w-auto">Places</label>
											<div class="flex items-center border border-border rounded-lg overflow-hidden shrink-0">
												<button type="submit" name="quantity" value="{{ item.quantity - 1 }}" class="px-3 py-2 text-foreground hover:bg-secondary transition-colors cursor-pointer {{ item.quantity <= 1 ? 'opacity-30 pointer-events-none' : '' }}">−</button>
												<span class="px-4 py-2 font-bold text-primary border-x border-border tabular-nums">{{ item.quantity }}</span>
												<button type="submit" name="quantity" value="{{ item.quantity + 1 }}" class="px-3 py-2 text-foreground hover:bg-secondary transition-colors cursor-pointer {{ item.quantity >= remaining ? 'opacity-30 pointer-events-none' : '' }}">+</button>
											</div>
										</form>

										<div class="text-left sm:text-right min-w-0 w-full sm:w-auto sm:shrink-0 border-t border-border pt-3 sm:border-0 sm:pt-0">
											<div class="text-xs text-muted-foreground">{{ unitPrice|number_format(0, ',', ' ') }}
												€ ×
												{{ item.quantity }}</div>
											<div class="text-lg font-bold text-primary tabular-nums">{{ lineTotal|number_format(0, ',', ' ') }}
												€</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>

				{# Récapitulatif #}
				<div class="lg:col-span-1 min-w-0">
					<div class="sticky top-8 p-4 sm:p-8 bg-(--card) border border-primary/50 rounded-lg min-w-0">
						<h2 class="text-xl font-bold text-foreground mb-6">Récapitulatif</h2>

						<div class="space-y-4 text-sm">
							{% for item in cart.cartItems %}
								{% set restaurant = item.restaurant %}
								<div class="flex justify-between">
									<span class="text-muted-foreground truncate mr-2">{{ restaurant.name }}
										×
										{{ item.quantity }}</span>
									<span class="font-semibold text-foreground flex-shrink-0">{{ (restaurant.ticketPrice * item.quantity)|number_format(0, ',', ' ') }}
										€</span>
								</div>
							{% endfor %}

							<hr class="border-border">

							<div class="flex justify-between">
								<span class="text-muted-foreground">Frais de service</span>
								<span class="font-semibold text-primary">Inclus</span>
							</div>

							<hr class="border-border">

							<div class="flex justify-between text-lg">
								<span class="font-bold text-foreground">Total</span>
								<span class="font-bold text-primary">{{ total|number_format(0, ',', ' ') }}
									€</span>
							</div>
						</div>

						<div class="mt-8">
							<form method="post" action="{{ path('app_checkout') }}" data-turbo="false">
								<input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
								<button type="submit" class="w-full py-4 bg-primary hover:bg-primary/90 text-white font-semibold rounded-lg transition-colors text-center">
									Passer commande —
									{{ total|number_format(0, ',', ' ') }}
									€
								</button>
							</form>
							<p class="text-xs text-muted-foreground text-center mt-3">Paiement sécurisé par Stripe</p>
						</div>

						<div class="mt-6 pt-6 border-t border-border space-y-2">
							{% for item in ['Paiement sécurisé', 'Confirmation immédiate', 'QR Code par ticket', 'Annulation possible'] %}
								<div class="flex items-center gap-2 text-sm">
									<svg class="size-4 text-primary shrink-0" aria-hidden="true"><use href="#icon-check"/></svg>
									<span class="text-muted-foreground">{{ item }}</span>
								</div>
							{% endfor %}
						</div>
					</div>
				</div>

			</div>

		{% endif %}
	</div>

{% endblock %}
