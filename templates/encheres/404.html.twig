{% extends 'base.html.twig' %}

{% block title %}Page introuvable — Carte Blanche{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center">

    <div class="relative mb-8 select-none">
        <span class="text-[180px] font-black leading-none text-white/5 pointer-events-none">
            404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
            <p class="text-white/20 text-lg uppercase tracking-[0.3em] font-light">
                Enchère introuvable
            </p>
        </div>
    </div>

    <h1 class="text-2xl font-bold text-white mb-3">
        Cette page n'existe pas
    </h1>
    <p class="text-white/50 max-w-sm mb-10 leading-relaxed">
        Le restaurant ou la page que vous cherchez a peut-être été vendu, retiré ou déplacé.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
        <a
            href="{{ path('app_encheres') }}"
            class="px-6 py-3 bg-(--color-primary) text-black font-semibold rounded-xl transition-colors text-sm"
        >
            Voir les enchères
        </a>
        <a
            href="{{ path('app_home') }}"
            class="px-6 py-3 border border-white/20 hover:border-white/40 text-white/70 hover:text-white rounded-xl transition-colors text-sm"
        >
            Retour à l'accueil
        </a>
    </div>

</div>
{% endblock %}
