{% extends 'base.html.twig' %}

{% block title %}{{ restaurant.name }}{% endblock %}

{% block body %}
	{% for type, message in app.flashes %}
		<div class="alert alert-{{ type }}" role="alert">
			{{ message|join(', ') }}
		</div>
	{% endfor %}
	<div class="p-8">
		<div class="flex flex-wrap items-center gap-4">
			<h1 class="text-3xl font-bold">{{ restaurant.name }}</h1>
			{% if app.user %}
				{% if isFavorite %}
					<form method="post" action="{{ path('app_favorite_remove', { id: restaurant.id }) }}" class="inline">
						<input type="hidden" name="_token" value="{{ csrf_token('favorite_remove_' ~ restaurant.id) }}">
						<button type="submit" class="rounded-lg border border-gray-500 bg-transparent px-4 py-2 text-sm font-medium text-white hover:bg-white/10 transition">
							Retirer des favoris
						</button>
					</form>
				{% else %}
					<form method="post" action="{{ path('app_favorite_add', { id: restaurant.id }) }}" class="inline">
						<input type="hidden" name="_token" value="{{ csrf_token('favorite_add_' ~ restaurant.id) }}">
						<button type="submit" class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary/90 transition">
							Ajouter aux favoris
						</button>
					</form>
				{% endif %}
			{% endif %}
		</div>
		<p class="text-gray-400 mt-2">{{ restaurant.address }}</p>
		<p class="mt-4">Prix de départ : {{ restaurant.askingPrice|number_format(0, ',', ' ') }} €</p>
	</div>
{% endblock %}
