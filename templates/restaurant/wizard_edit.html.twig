{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ restaurant.name }} — Étape {{ step }}/4{% endblock %}

{% block body %}
    <section class="p-6 md:p-10 space-y-6">
        <header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div class="flex items-center gap-4">
                <a href="{{ path('app_restaurant_index') }}" class="text-muted-foreground hover:text-white transition-colors text-sm">
                    ← Mes restaurants
                </a>
                <div>
                    <h1 class="text-3xl font-bold">{{ restaurant.name }}</h1>
                    <p class="text-sm text-muted-foreground">Modifier l'annonce</p>
                </div>
            </div>
            {{ include('restaurant/_wizard_progress.html.twig', {currentStep: step}) }}
        </header>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-lg border border-border bg-secondary/30 px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

            {% if step == 1 %}
                {{ include('restaurant/_wizard_step1.html.twig') }}
            {% elseif step == 2 %}
                {{ include('restaurant/_wizard_step2.html.twig') }}
            {% elseif step == 3 %}
                {{ include('restaurant/_wizard_step3.html.twig') }}
            {% elseif step == 4 %}
                {{ include('restaurant/_wizard_step4.html.twig', {restaurant: restaurant}) }}
            {% endif %}

            <div class="flex gap-4">
                {% if step > 1 %}
                    <a href="{{ path('app_restaurant_edit_step', {id: restaurant.id, step: step - 1}) }}" class="secondary-btn">← Précédent</a>
                {% endif %}
                <button type="submit" class="primary-btn">
                    {% if step < 4 %}Enregistrer et continuer →{% else %}Enregistrer{% endif %}
                </button>
                <a href="{{ path('app_restaurant_index') }}" class="secondary-btn">Annuler</a>
            </div>

        {{ form_end(form) }}

        {% if step == 4 %}
            {% if restaurant.images|length > 0 %}
                {% for image in restaurant.images %}
                    {% if image.fileName %}
                        <form id="delete-image-{{ image.id }}"
                              method="post"
                              action="{{ path('app_restaurant_image_delete', {restaurantId: restaurant.id, imageId: image.id}) }}"
                              class="hidden">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_image_' ~ image.id) }}">
                        </form>
                    {% endif %}
                {% endfor %}
            {% endif %}

            <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-6 space-y-4">
                <h2 class="text-lg font-semibold text-red-400">Zone dangereuse</h2>
                <p class="text-sm text-muted-foreground">La suppression est définitive et irréversible.</p>
                <form method="post"
                      action="{{ path('app_restaurant_delete', {id: restaurant.id}) }}"
                      onsubmit="return confirm('Supprimer « {{ restaurant.name }} » ? Cette action est irréversible.')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_restaurant_' ~ restaurant.id) }}">
                    <button type="submit" class="rounded-md border border-red-500/40 bg-red-500/10 px-4 py-2 text-sm text-red-400 hover:bg-red-500/20 transition-colors">
                        Supprimer ce restaurant
                    </button>
                </form>
            </div>
        {% endif %}
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if step == 2 or step == 4 %}
        {{ include('restaurant/_address_autocomplete_script.html.twig', { googleMapsApiKey: googleMapsApiKey }) }}
    {% endif %}
    {% if step == 4 %}
        {{ include('restaurant/_auction_datetime_picker_script.html.twig') }}
        {{ include('restaurant/_image_upload_repeater_script.html.twig') }}
    {% endif %}
{% endblock %}
