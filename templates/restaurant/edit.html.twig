{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ restaurant.name }}{% endblock %}

{% block body %}
    <div id="restaurant-form-config" class="hidden" data-google-maps-key="{{ googleMapsApiKey|default('')|e('html_attr') }}" data-generate-description-url="{{ path('app_restaurant_generate_description') }}"></div>
    <section class="p-6 md:p-10 space-y-6">
        <header class="flex items-center gap-4">
            <a href="{{ path('app_restaurant_index') }}" class="text-muted-foreground hover:text-white transition-colors text-sm">
                Mes restaurants
            </a>
            <div>
                <h1 class="text-4xl sm:text-5xl font-bold">{{ restaurant.name }}</h1>
                <p class="text-muted-foreground mt-1">Modifier l'annonce</p>
            </div>
        </header>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-lg border border-border bg-secondary/30 px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}

            <div class="rounded-xl border border-border bg-secondary/20 p-6 space-y-4">
                 <h2 class="text-2xl font-bold flex items-center gap-3">
                    <span class="w-1 h-8 bg-primary rounded-full inline-block shrink-0"></span>
                    Informations du restaurant
                </h2>
                <div class="grid gap-4 md:grid-cols-2">
                    <div class="md:col-span-2">
                        {{ form_label(form.name, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.name) }}</div>
                    </div>
                    <div class="md:col-span-2">
                        <div class="flex items-center justify-between mb-2">
                            {{ form_label(form.description, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                            <button type="button" id="btn-generate-description"
                                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md text-primary hover:bg-primary/10 text-sm font-medium transition-colors cursor-pointer">
                                <svg id="icon-generate" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                                </svg>
                                <svg id="icon-loading" class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                                </svg>
                                <span id="btn-generate-label">Générer avec IA</span>
                            </button>
                        </div>
                        {{ form_widget(form.description, {'attr': {
                            'class': 'w-full rounded-md border border-border bg-background px-3 py-2 text-sm min-h-[120px] focus:outline-none focus:ring-2 focus:ring-primary/40',
                            'id': 'restaurant-description'
                        }}) }}
                        <span id="ai-status" class="hidden mt-2 text-xs px-3 py-1 rounded-full border"></span>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.description) }}</div>
                    </div>
                    <div class="md:col-span-2">
                        {{ form_label(form.address, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex items-center rounded-md border border-border bg-background focus-within:ring-2 focus-within:ring-primary/40">
                            <span class="flex items-center pl-3 shrink-0 text-muted-foreground">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </span>
                            {{ form_widget(form.address, {'attr': {
                                'class': 'flex-1 min-w-0 bg-transparent px-3 py-2 text-sm border-0 focus:outline-none focus:ring-0',
                                'placeholder': 'Commencez à saisir une adresse...'
                            }}) }}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.address) }}</div>
                        <p class="text-xs text-muted-foreground mt-1">Sélectionnez une suggestion pour renseigner automatiquement la latitude et la longitude.</p>
                    </div>
                    <div class="hidden" aria-hidden="true">
                        {{ form_widget(form.latitude, {'attr': {'class': 'hidden', 'data-address-autocomplete-target': 'latitude'}}) }}
                        {{ form_widget(form.longitude, {'attr': {'class': 'hidden', 'data-address-autocomplete-target': 'longitude'}}) }}
                    </div>
                    <div class="md:col-span-2">
                        <div class="text-red-400 text-xs">{{ form_errors(form.latitude) }}</div>
                        <div class="text-red-400 text-xs">{{ form_errors(form.longitude) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.capacity, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex items-center rounded-md border border-border bg-background focus-within:ring-2 focus-within:ring-primary/40">
                            <span class="flex items-center pl-3 shrink-0 text-muted-foreground">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                                </svg>
                            </span>
                            {{ form_widget(form.capacity, {'attr': {
                                'class': 'flex-1 min-w-0 bg-transparent px-3 py-2 text-sm border-0 focus:outline-none focus:ring-0'
                            }}) }}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.capacity) }}</div>
                    </div>
                    <div class="md:col-span-2">
                        {{ form_label(form.categories, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex flex-wrap gap-2 rounded-lg border border-border bg-background/40 p-3">
                            {% for categoryField in form.categories %}
                                <label class="cursor-pointer">
                                    {{ form_widget(categoryField, {'attr': {'class': 'sr-only peer'}}) }}
                                    <span class="inline-flex items-center rounded-full border border-border px-3 py-1.5 text-sm text-muted-foreground transition-colors peer-checked:border-primary peer-checked:bg-primary peer-checked:text-white hover:border-primary/60 hover:text-white">
                                        {{ categoryField.vars.label }}
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.categories) }}</div>
                    </div>
                </div>
            </div>

            <div class="rounded-xl border border-border bg-secondary/20 p-6 space-y-4">
                <h2 class="text-lg font-semibold">Informations financières</h2>
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        {{ form_label(form.askingPrice, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.askingPrice, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.askingPrice) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.annualRevenue, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.annualRevenue, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.annualRevenue) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.rent, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.rent, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.rent) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.leaseRemaining, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.leaseRemaining, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.leaseRemaining) }}</div>
                    </div>
                    <div class="md:col-span-2">
                        {{ form_label(form.pappersUrl, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.pappersUrl, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.pappersUrl) }}</div>
                    </div>
                </div>
            </div>

            <div class="rounded-xl border border-border bg-secondary/20 p-6 space-y-4">
                <h2 class="text-lg font-semibold">Enchère</h2>
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        {{ form_label(form.auctionDate, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.auctionDate, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2', 'data-auction-picker': 'date'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.auctionDate) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.auctionTime, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex items-center rounded-md border border-border bg-background focus-within:ring-2 focus-within:ring-primary/40">
                            <span class="flex items-center pl-3 shrink-0 text-muted-foreground">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" stroke-width="2"/>
                                    <polyline points="12 6 12 12 16 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            {{ form_widget(form.auctionTime, {'attr': {
                                'class': 'flex-1 min-w-0 bg-transparent px-3 py-2 text-sm border-0 focus:outline-none focus:ring-0',
                                'data-auction-picker': 'time'
                            }}) }}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.auctionTime) }}</div>
                    </div>
                    <div class="md:col-span-2">
                        {{ form_label(form.auctionLocation, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex items-center rounded-md border border-border bg-background focus-within:ring-2 focus-within:ring-primary/40">
                            <span class="flex items-center pl-3 shrink-0 text-muted-foreground">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </span>
                            {{ form_widget(form.auctionLocation, {'attr': {
                                'class': 'flex-1 min-w-0 bg-transparent px-3 py-2 text-sm border-0 focus:outline-none focus:ring-0',
                                'placeholder': "Commencez à saisir un lieu d'enchère..."
                            }}) }}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.auctionLocation) }}</div>
                        <p class="text-xs text-muted-foreground mt-1">Sélectionnez un lieu pour enregistrer automatiquement ses coordonnées.</p>
                    </div>
                    <div class="hidden" aria-hidden="true">
                        {{ form_widget(form.auctionLocationLat) }}
                        {{ form_widget(form.auctionLocationLng) }}
                    </div>
                    <div>
                        {{ form_label(form.ticketPrice, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                        {{ form_widget(form.ticketPrice, {'attr': {'class': 'mt-1 w-full rounded-md border border-border bg-background px-3 py-2'}}) }}
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.ticketPrice) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.maxCapacity, null, {'label_attr': {'class': 'text-sm font-medium'}}) }}
                        <div class="mt-2 flex items-center rounded-md border border-border bg-background focus-within:ring-2 focus-within:ring-primary/40">
                            <span class="flex items-center pl-3 shrink-0 text-muted-foreground">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                                </svg>
                            </span>
                            {{ form_widget(form.maxCapacity, {'attr': {
                                'class': 'flex-1 min-w-0 bg-transparent px-3 py-2 text-sm border-0 focus:outline-none focus:ring-0'
                            }}) }}
                        </div>
                        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.maxCapacity) }}</div>
                    </div>
                </div>
            </div>

            <div class="rounded-xl border border-border bg-secondary/20 p-6 space-y-4">
                <h2 class="text-2xl font-bold flex items-center gap-3">
                    <span class="w-1 h-8 bg-primary rounded-full inline-block shrink-0"></span>
                    Images
                </h2>

                {% if restaurant.images|length > 0 %}
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                        {% for image in restaurant.images %}
                            {% if image.fileName %}
                                <div class="relative group rounded-lg overflow-hidden border border-border">
                                    <img src="{{ asset('uploads/restaurants/' ~ image.fileName) }}"
                                         alt="Image {{ loop.index }}"
                                         class="w-full h-36 object-cover">
                                    <div class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button type="submit"
                                                form="delete-image-{{ image.id }}"
                                                onclick="return confirm('Supprimer cette image ?')"
                                                class="rounded-md bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition-colors">
                                            Supprimer
                                        </button>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-sm text-muted-foreground">Aucune image pour ce restaurant.</p>
                {% endif %}

                <div class="pt-2 border-t border-border/50">
                    <p class="text-sm text-muted-foreground mb-2">Ajouter des images — JPEG, PNG, WebP — 5 Mo max.</p>
                    {{ form_label(form.uploadedImages, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}
                    <div data-image-upload-wrapper class="space-y-3">
                        <div data-image-upload-group
                             data-input-name="{{ form.vars.name }}[uploadedImages][]"
                             data-input-id-prefix="{{ form.uploadedImages.vars.id }}"
                             class="space-y-3">
                            <div data-image-upload-row class="rounded-lg border border-border/70 bg-background/30 p-3">
                                <div class="flex flex-col gap-2 md:flex-row md:items-center">
                                    <input type="file"
                                           id="{{ form.uploadedImages.vars.id }}_0"
                                           name="{{ form.vars.name }}[uploadedImages][]"
                                           accept="image/jpeg,image/png,image/webp"
                                           class="block w-full text-sm text-muted-foreground file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary/80 cursor-pointer">
                                    <button type="button"
                                            data-remove-image-input
                                            class="hidden rounded-md border border-red-500/40 bg-red-500/10 px-3 py-2 text-xs text-red-300 hover:bg-red-500/20 transition-colors">
                                        Supprimer
                                    </button>
                                </div>
                                <p data-file-name class="mt-2 text-xs text-muted-foreground">Aucun fichier sélectionné</p>
                            </div>
                        </div>

                        <button type="button"
                                data-add-image-input
                                class="inline-flex items-center rounded-md border border-primary/40 bg-primary/10 px-3 py-2 text-sm text-primary hover:bg-primary hover:text-white transition-colors">
                            + Ajouter une autre image
                        </button>
                    </div>
                    {% do form.uploadedImages.setRendered %}
                    <div class="text-red-400 text-xs mt-1">{{ form_errors(form.uploadedImages) }}</div>
                    <p class="text-xs text-muted-foreground mt-1">Ajoutez les images une par une avec le bouton, ou utilisez Ctrl/Cmd dans le sélecteur.</p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button type="submit"
                        class="flex-1 inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
                    Enregistrer les modifications
                </button>
                <a href="{{ path('app_restaurant_index') }}"
                   class="inline-flex items-center justify-center rounded-lg border border-border px-6 py-3 text-sm font-medium text-muted-foreground hover:bg-secondary/60 hover:text-white transition-colors">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}

        {# Formulaires hidden pour suppression d'images #}
        {% if restaurant.images|length > 0 %}
            {% for image in restaurant.images %}
                {% if image.fileName %}
                    <form id="delete-image-{{ image.id }}"
                          method="post"
                          action="{{ path('app_restaurant_image_delete', {restaurantId: restaurant.id, imageId: image.id}) }}"
                          class="hidden">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_image_' ~ image.id) }}">
                    </form>
                {% endif %}
            {% endfor %}
        {% endif %}

        {# ── Soumettre pour validation (visible uniquement en brouillon) ── #}
        {% if restaurant.status.value == 'brouillon' %}
            <div class="rounded-xl border border-primary/30 bg-primary/5 p-6 space-y-4">
                <div class="flex items-start gap-4">
                    <div class="shrink-0 w-10 h-10 rounded-full bg-primary/15 flex items-center justify-center">
                        <svg class="size-5 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-foreground">Soumettre pour validation</h2>
                        <p class="text-sm text-muted-foreground mt-1">
                            Une fois soumis, notre équipe examinera votre annonce et vous recevrez un email de confirmation.
                            Assurez-vous que toutes les informations sont complètes avant de soumettre.
                        </p>
                    </div>
                </div>
                <form method="post"
                      action="{{ path('app_restaurant_submit', { id: restaurant.id }) }}"
                      onsubmit="return confirm('Soumettre « {{ restaurant.name }} » pour validation ? Vous ne pourrez plus le modifier jusqu\'à la décision de l\'équipe.')">
                    <input type="hidden" name="_token" value="{{ csrf_token('submit_restaurant_' ~ restaurant.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
                        </svg>
                        Soumettre pour validation
                    </button>
                </form>
            </div>
        {% elseif restaurant.status.value == 'en_moderation' %}
            <div class="rounded-xl border border-yellow-500/30 bg-yellow-500/5 p-5 flex items-center gap-4">
                <div class="shrink-0 w-9 h-9 rounded-full bg-yellow-500/15 flex items-center justify-center">
                    <svg class="size-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-yellow-400">En attente de validation</p>
                    <p class="text-xs text-muted-foreground mt-0.5">Votre annonce est en cours d'examen par notre équipe. Vous recevrez un email dès qu'une décision sera prise.</p>
                </div>
            </div>
        {% endif %}

        {# ── Zone dangereuse ── #}
        <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-8 space-y-4">
            <h2 class="text-xl font-bold text-red-400 flex items-center gap-3">
                <span class="w-1 h-7 bg-red-500 rounded-full inline-block shrink-0"></span>
                Zone dangereuse
            </h2>
            <p class="text-sm text-muted-foreground">La suppression est définitive et irréversible.</p>
            <form method="post"
                  action="{{ path('app_restaurant_delete', {id: restaurant.id}) }}"
                  onsubmit="return confirm('Supprimer « {{ restaurant.name }} » ? Cette action est irréversible.')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_restaurant_' ~ restaurant.id) }}">
                 <button type="submit"
                        class="inline-flex items-center rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/20 transition-colors">
                    Supprimer ce restaurant
                </button>
            </form>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ importmap('restaurant-form') }}
{% endblock %}
