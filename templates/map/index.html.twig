{% extends 'base.html.twig' %}

{% block title %}Carte des restaurants
{% endblock %}

{% block body %}
	<div
		class="map-page" data-turbo="false">

		{# ══════ MOBILE : page scrollable ══════ #}
		<div
			class="md:hidden">
			{# Section titre #}
			<div class="flex flex-col items-center justify-center px-5 pt-6 pb-4">
				<div class="flex items-center gap-3 mb-2">
					<svg class="size-6 text-primary flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
						<circle cx="12" cy="10" r="3"/>
					</svg>
					<h1 class="text-2xl font-bold text-white">Carte des enchères</h1>
				</div>
				<p class="text-gray-400 text-center">Explorez les restaurants disponibles aux enchères</p>
				<div class="mt-3 flex items-center gap-2">
					<span id="restaurant-count-mobile" class="text-2xl font-bold text-primary">0</span>
					<span class="text-sm text-gray-400">restaurants disponibles</span>
				</div>
			</div>

			{# Carte en rounded #}
			<div class="px-4 pb-6">
				<div id="map-mobile" class="w-full h-[60vh] rounded-2xl overflow-hidden border border-white/10"></div>
			</div>

			{# Liste restaurants en grand #}
			<div class="px-4 pb-8">
				<h2 class="text-lg font-semibold text-white mb-4">Tous les restaurants</h2>
				<div id="restaurant-list-mobile" class="flex flex-col gap-4"></div>
			</div>
		</div>

		{# ══════ DESKTOP : layout fixe avec sidebar ══════ #}
		<section
			class="hidden md:block relative w-full overflow-hidden h-screen">
			{# Sidebar #}
			<div id="map-sidebar" class="map-sidebar-open absolute top-0 left-0 z-20 w-[420px] h-full flex flex-col bg-black/95 backdrop-blur-md border-r border-white/10 transition-transform duration-300">
				<div class="p-6 border-b border-white/10 flex-shrink-0">
					<div class="flex items-center gap-3 mb-2">
						<svg class="size-6 text-primary flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
							<circle cx="12" cy="10" r="3"/>
						</svg>
						<h1 class="text-2xl font-bold text-white">Carte des enchères</h1>
					</div>
					<p class="text-sm text-gray-400">Explorez les restaurants disponibles aux enchères</p>
					<div class="mt-4 flex items-center gap-2">
						<span id="restaurant-count" class="text-2xl font-bold text-primary">0</span>
						<span class="text-sm text-gray-400">restaurants disponibles</span>
					</div>
				</div>
				<div id="map-sidebar-detail" class="hidden flex-shrink-0 border-b border-white/10 overflow-hidden"></div>
				<div id="restaurant-list" class="p-4 flex flex-col gap-3 overflow-y-auto flex-1 min-h-0"></div>
			</div>

			{# Carte plein écran #}
			<div id="map" class="absolute inset-0 z-0 w-full h-full"></div>

			{# Bouton toggle sidebar #}
			<button id="toggle-sidebar-desktop" class="absolute top-4 left-[10px] z-30 p-2.5 rounded-xl cursor-pointer bg-black/80 backdrop-blur-md border border-white/10 text-white" aria-label="Toggle sidebar">
				<svg class="size-6" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M3 12h18M3 6h18M3 18h18"/>
				</svg>
			</button>

			{# Zoom controls #}
			<div id="map-zoom-controls" class="absolute top-4 right-4 z-30 flex flex-col rounded-xl overflow-hidden border border-white/10 shadow-lg bg-gray-900/95">
				<button type="button" data-zoom-in class="w-12 h-12 flex items-center justify-center text-white font-bold text-lg hover:bg-primary/40" aria-label="Zoom avant">+</button>
				<button type="button" data-zoom-out class="w-12 h-12 flex items-center justify-center text-white font-bold text-lg hover:bg-primary/40 border-t border-white/10" aria-label="Zoom arrière">−</button>
			</div>
		</section>
	</div>

	<div id="map-config" data-token="{{ mapboxToken }}" data-api-url="{{ path('app_api_map_restaurants') }}" style="display: none;"></div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	{{ importmap('map') }}
{% endblock %}
