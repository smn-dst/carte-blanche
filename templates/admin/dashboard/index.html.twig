{% extends 'base.html.twig' %}

{% block title %}Vue d'ensemble — Admin{% endblock %}

{% block body %}
<div class="p-6 md:p-10 space-y-8">

	{# ── En-tête ── #}
	<div>
		<p class="text-xs text-primary uppercase tracking-widest font-semibold mb-1">Administration</p>
		<h1 class="text-3xl sm:text-4xl font-bold text-foreground">Vue d'ensemble</h1>
		<p class="text-muted-foreground mt-1">Statistiques globales de la plateforme</p>
	</div>

	{# ── Cards ── #}
	<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">

		{# Utilisateurs #}
		<div class="rounded-xl border border-border bg-card p-6 space-y-3">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
					<svg class="size-4 text-primary" aria-hidden="true"><use href="#icon-users"/></svg>
				</div>
				<p class="text-sm font-medium text-muted-foreground">Utilisateurs</p>
			</div>
			<p class="text-3xl font-bold text-foreground tabular-nums">{{ users.total }}</p>
			<p class="text-xs text-muted-foreground">
				{{ users.buyers }} acheteur{{ users.buyers > 1 ? 's' : '' }}
				&middot;
				{{ users.vendors }} vendeur{{ users.vendors > 1 ? 's' : '' }}
			</p>
		</div>

		{# Chiffre d'affaires #}
		<div class="rounded-xl border border-border bg-card p-6 space-y-3">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
					<svg class="size-4 text-primary" aria-hidden="true"><use href="#icon-euro"/></svg>
				</div>
				<p class="text-sm font-medium text-muted-foreground">Chiffre d'affaires</p>
			</div>
			<p class="text-3xl font-bold text-foreground tabular-nums">{{ orders.totalRevenue|number_format(0, ',', ' ') }} €</p>
			<p class="text-xs text-muted-foreground">
				{{ orders.orderCount }} commande{{ orders.orderCount > 1 ? 's' : '' }} aboutie{{ orders.orderCount > 1 ? 's' : '' }}
			</p>
		</div>

		{# Remboursements #}
		<div class="rounded-xl border border-border bg-card p-6 space-y-3">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
					<svg class="size-4 text-primary" aria-hidden="true"><use href="#icon-ticket-x"/></svg>
				</div>
				<p class="text-sm font-medium text-muted-foreground">Remboursements</p>
			</div>
			<p class="text-3xl font-bold text-foreground tabular-nums">{{ refundsTotal }}</p>
			<p class="text-xs {% if refundsPending > 0 %}text-yellow-400{% else %}text-muted-foreground{% endif %}">
				{{ refundsPending }} demande{{ refundsPending > 1 ? 's' : '' }} en attente
			</p>
		</div>

		{# Restaurants #}
		<div class="rounded-xl border border-border bg-card p-6 space-y-3">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
					<svg class="size-4 text-primary" aria-hidden="true"><use href="#icon-gavel"/></svg>
				</div>
				<p class="text-sm font-medium text-muted-foreground">Restaurants actifs</p>
			</div>
			<p class="text-3xl font-bold text-foreground tabular-nums">{{ restaurantsActive }}</p>
			<p class="text-xs {% if restaurantsPending > 0 %}text-yellow-400{% else %}text-muted-foreground{% endif %}">
				{{ restaurantsPending }} annonce{{ restaurantsPending > 1 ? 's' : '' }} en modération
			</p>
		</div>

		{# Demandes vendeur #}
		<div class="rounded-xl border border-border bg-card p-6 space-y-3">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
					<svg class="size-4 text-primary" aria-hidden="true"><use href="#icon-store"/></svg>
				</div>
				<p class="text-sm font-medium text-muted-foreground">Demandes vendeur</p>
			</div>
			<p class="text-3xl font-bold text-foreground tabular-nums">{{ vendorRequestsTotal }}</p>
			<p class="text-xs {% if vendorRequestsPending > 0 %}text-yellow-400{% else %}text-muted-foreground{% endif %}">
				{{ vendorRequestsPending }} demande{{ vendorRequestsPending > 1 ? 's' : '' }} en attente
			</p>
		</div>

	</div>

</div>
{% endblock %}
