{% extends 'base.html.twig' %}

{% block title %}Remboursements — Admin{% endblock %}

{% block body %}
<div class="p-6 md:p-10 space-y-10">

    {# ── En-tête ── #}
    <div>
        <p class="text-xs text-primary uppercase tracking-widest font-semibold mb-1">Administration</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-foreground">Remboursements</h1>
        <p class="text-muted-foreground mt-1">
            {{ pending|length }} demande{{ pending|length > 1 ? 's' : '' }} en attente
            · {{ processed|length }} traitée{{ processed|length > 1 ? 's' : '' }}
        </p>
    </div>

    {# ── Flashes ── #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-lg border text-sm
                {{ type == 'success' ? 'bg-green-500/10 border-green-500/30 text-green-400' : 'bg-red-500/10 border-red-500/30 text-red-400' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# ════════════════════════════════════════
       SECTION 1 — DEMANDES EN ATTENTE
    ════════════════════════════════════════ #}
    <section>
        <h2 class="text-xl font-bold text-foreground mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-yellow-400 inline-block"></span>
            Demandes en attente
            {% if pending|length > 0 %}
                <span class="ml-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-500/15 text-yellow-400 border border-yellow-500/20">
                    {{ pending|length }}
                </span>
            {% endif %}
        </h2>

        {% if pending is empty %}
            <div class="flex items-center gap-3 p-5 rounded-xl border border-border bg-secondary/10 text-muted-foreground text-sm">
                <svg class="size-5 shrink-0 opacity-50" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                Aucune demande en attente. Tout est traité !
            </div>
        {% else %}
            <div class="space-y-4">
                {% for refund in pending %}
                    {% set order = refund.order %}
                    {% set buyer = order ? order.buyer : null %}

                    {# Restaurants impliqués #}
                    {% set restaurantNames = [] %}
                    {% if order %}
                        {% for ticket in order.tickets %}
                            {% if ticket.restaurant and ticket.restaurant.name not in restaurantNames %}
                                {% set restaurantNames = restaurantNames|merge([ticket.restaurant.name]) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    <div class="rounded-xl border border-yellow-500/20 bg-yellow-500/5 p-5 space-y-4">

                        {# ─ Infos utilisateur + commande ─ #}
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                            <div class="space-y-1">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="font-semibold text-foreground">
                                        {% if buyer %}{{ buyer.firstName }} {{ buyer.lastName }}{% else %}Utilisateur inconnu{% endif %}
                                    </span>
                                    {% if buyer %}
                                        <span class="text-xs text-muted-foreground">{{ buyer.email }}</span>
                                    {% endif %}
                                </div>
                                {% if order %}
                                    <p class="text-xs text-muted-foreground">
                                        Commande <span class="font-mono text-primary font-semibold">{{ order.reference }}</span>
                                        · {{ order.totalAmount|number_format(0, ',', ' ') }} €
                                        · {{ order.tickets|length }} ticket{{ order.tickets|length > 1 ? 's' : '' }}
                                    </p>
                                {% endif %}
                                {% if restaurantNames is not empty %}
                                    <p class="text-xs text-muted-foreground">
                                        Restaurant{{ restaurantNames|length > 1 ? 's' : '' }} : {{ restaurantNames|join(', ') }}
                                    </p>
                                {% endif %}
                                <p class="text-xs text-muted-foreground">
                                    Demande déposée le {{ refund.createdAt ? refund.createdAt|date('d/m/Y à H:i') : '—' }}
                                </p>
                            </div>

                            {# Montant en vedette #}
                            <div class="shrink-0 text-right">
                                <p class="text-2xl font-bold text-yellow-400">{{ refund.amount|number_format(0, ',', ' ') }} €</p>
                                <p class="text-xs text-muted-foreground">à rembourser</p>
                            </div>
                        </div>

                        {# ─ Motif ─ #}
                        <div class="rounded-lg border border-border bg-background/50 px-4 py-3">
                            <p class="text-xs text-muted-foreground uppercase tracking-wider font-semibold mb-1">Motif de la demande</p>
                            <p class="text-sm text-foreground">{{ refund.reasonRefund }}</p>
                        </div>

                        {# ─ Boutons Approuver / Refuser ─ #}
                        <div class="flex flex-col sm:flex-row gap-3 pt-1">

                            <form method="post" action="{{ path('app_admin_refund_approve', { id: refund.id }) }}"
                                  onsubmit="return confirm('Approuver et déclencher le remboursement Stripe de {{ refund.amount|number_format(0, ',', ' ') }} € ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_refund_' ~ refund.id) }}">
                                <button type="submit"
                                    class="w-full sm:w-auto flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-green-600 hover:bg-green-500 text-white text-sm font-semibold transition-colors">
                                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    Approuver le remboursement
                                </button>
                            </form>

                            <form method="post" action="{{ path('app_admin_refund_reject', { id: refund.id }) }}"
                                  onsubmit="return confirm('Refuser la demande de remboursement de {{ buyer ? buyer.firstName ~ ' ' ~ buyer.lastName : 'cet utilisateur' }} ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_refund_' ~ refund.id) }}">
                                <button type="submit"
                                    class="w-full sm:w-auto flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg border border-red-500/30 text-red-400 hover:bg-red-500/10 text-sm font-semibold transition-colors">
                                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                    Refuser la demande
                                </button>
                            </form>

                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    {# ════════════════════════════════════════
       SECTION 2 — HISTORIQUE DES REMBOURSEMENTS
    ════════════════════════════════════════ #}
    <section>
        <h2 class="text-xl font-bold text-foreground mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-muted-foreground inline-block"></span>
            Historique des remboursements
        </h2>

        {% if processed is empty %}
            <p class="text-muted-foreground text-sm">Aucun remboursement traité pour le moment.</p>
        {% else %}
            <div class="overflow-x-auto rounded-xl border border-border">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-border bg-secondary/30 text-left">
                            <th class="px-4 py-3 font-semibold text-muted-foreground">Utilisateur</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground hidden md:table-cell">Commande</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground hidden lg:table-cell">Motif</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground text-right">Montant</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground hidden lg:table-cell">Traité par</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground hidden md:table-cell">Date</th>
                            <th class="px-4 py-3 font-semibold text-muted-foreground">Statut</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        {% for refund in processed %}
                            {% set order = refund.order %}
                            {% set buyer = order ? order.buyer : null %}
                            <tr class="hover:bg-secondary/20 transition-colors">

                                {# Utilisateur #}
                                <td class="px-4 py-3">
                                    {% if buyer %}
                                        <p class="font-medium text-foreground">{{ buyer.firstName }} {{ buyer.lastName }}</p>
                                        <p class="text-xs text-muted-foreground">{{ buyer.email }}</p>
                                    {% else %}
                                        <span class="text-muted-foreground">—</span>
                                    {% endif %}
                                </td>

                                {# Référence commande #}
                                <td class="px-4 py-3 hidden md:table-cell">
                                    {% if order %}
                                        <span class="font-mono text-xs font-semibold text-primary">{{ order.reference }}</span>
                                        <p class="text-xs text-muted-foreground mt-0.5">{{ order.totalAmount|number_format(0, ',', ' ') }} € · {{ order.tickets|length }} ticket{{ order.tickets|length > 1 ? 's' : '' }}</p>
                                    {% else %}
                                        <span class="text-muted-foreground">—</span>
                                    {% endif %}
                                </td>

                                {# Motif (tronqué) #}
                                <td class="px-4 py-3 hidden lg:table-cell max-w-[200px]">
                                    <span class="line-clamp-2 text-muted-foreground" title="{{ refund.reasonRefund }}">
                                        {{ refund.reasonRefund }}
                                    </span>
                                </td>

                                {# Montant #}
                                <td class="px-4 py-3 text-right font-bold tabular-nums
                                    {{ refund.status.value == 'traite' ? 'text-green-400' : 'text-muted-foreground line-through' }}">
                                    {{ refund.amount|number_format(0, ',', ' ') }} €
                                </td>

                                {# Traité par #}
                                <td class="px-4 py-3 text-muted-foreground hidden lg:table-cell">
                                    {% if refund.processedBy %}
                                        {{ refund.processedBy.firstName }} {{ refund.processedBy.lastName }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>

                                {# Date #}
                                <td class="px-4 py-3 text-muted-foreground hidden md:table-cell">
                                    {{ refund.createdAt ? refund.createdAt|date('d/m/Y') : '—' }}
                                </td>

                                {# Statut #}
                                <td class="px-4 py-3">
                                    {% if refund.status.value == 'traite' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-500/10 text-green-400 border border-green-500/20">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
                                            Remboursé
                                        </span>
                                    {% elseif refund.status.value == 'refuse' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-red-500/10 text-red-400 border border-red-500/20">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-400 inline-block"></span>
                                            Refusé
                                        </span>
                                    {% endif %}
                                </td>

                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>

</div>
{% endblock %}
