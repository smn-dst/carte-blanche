{% extends 'base.html.twig' %}

{% block title %}Demandes vendeur — Admin
{% endblock %}

{% block body %}
	<div class="p-6 md:p-10 space-y-10">

		<div>
			<p class="text-xs text-primary uppercase tracking-widest font-semibold mb-1">Administration</p>
			<h1 class="text-3xl sm:text-4xl font-bold text-foreground">Demandes vendeur</h1>
			<p class="text-muted-foreground mt-1">
				{{ pending|length }}
				demande{{ pending|length > 1 ? 's' : '' }}
				en attente
				            ·
				{{ processed|length }}
				traitée{{ processed|length > 1 ? 's' : '' }}
			</p>
		</div>

		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="p-4 rounded-lg border text-sm
						                {{ type == 'success' ? 'bg-green-500/10 border-green-500/30 text-green-400' : 'bg-red-500/10 border-red-500/30 text-red-400' }}">
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}

		{# ════ EN ATTENTE ════ #}
		<section>
			<h2 class="text-xl font-bold text-foreground mb-4 flex items-center gap-2">
				<span class="w-2 h-2 rounded-full bg-yellow-400 inline-block"></span>
				En attente d'approbation
				{% if pending|length > 0 %}
					<span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-500/15 text-yellow-400 border border-yellow-500/20">{{ pending|length }}</span>
				{% endif %}
			</h2>

			{% if pending is empty %}
				<div class="flex items-center gap-3 p-5 rounded-xl border border-border bg-secondary/10 text-muted-foreground text-sm">
					<svg class="size-5 shrink-0 opacity-50" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
					</svg>
					Aucune demande en attente.
				</div>
			{% else %}
				<div class="space-y-5">
					{% for vendorRequest in pending %}
						{% set user = vendorRequest.user %}
						<div
							class="rounded-xl border border-yellow-500/20 bg-yellow-500/5 p-5 space-y-5">

							{# Infos utilisateur #}
							<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
								<div class="flex items-center gap-4">
									<div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-lg shrink-0">
										{% if user %}
											{{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}{% else %}?
										{% endif %}
									</div>
									<div>
										<p class="font-semibold text-foreground text-base">
											{% if user %}
												{{ user.firstName }}
												{{ user.lastName }}{% else %}Utilisateur inconnu
											{% endif %}
										</p>
										{% if user %}
											<p class="text-sm text-muted-foreground">{{ user.email }}</p>
											{% if user.phoneNumber %}
												<p class="text-xs text-muted-foreground mt-0.5">{{ user.phoneNumber }}</p>
											{% endif %}
										{% endif %}
									</div>
								</div>
								<div class="shrink-0 text-right">
									<p class="text-xs text-muted-foreground">Demande du</p>
									<p class="text-sm font-medium text-foreground">{{ vendorRequest.createdAt ? vendorRequest.createdAt|date('d/m/Y à H:i') : '—' }}</p>
									{% if user %}
										<p class="text-xs text-muted-foreground mt-1">Membre depuis
											{{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}</p>
									{% endif %}
								</div>
							</div>

							{# Motivation #}
							{% if vendorRequest.motivation %}
								<div class="rounded-lg border border-border bg-background/50 p-4">
									<p class="text-xs text-primary uppercase tracking-wider font-semibold mb-2">Motivation du candidat</p>
									<p class="text-sm text-foreground leading-relaxed">{{ vendorRequest.motivation }}</p>
								</div>
							{% else %}
								<div class="rounded-lg border border-border bg-background/30 p-3">
									<p class="text-xs text-muted-foreground italic">Aucune motivation renseignée (ancienne demande).</p>
								</div>
							{% endif %}

							{# Pièce d'identité #}
							<div class="flex items-center justify-between rounded-lg border border-border bg-background/50 px-4 py-3">
								<div class="flex items-center gap-3">
									<svg class="size-5 text-muted-foreground shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
									</svg>
									<div>
										<p class="text-xs text-primary uppercase tracking-wider font-semibold">Pièce d'identité</p>
										<p class="text-xs text-muted-foreground mt-0.5">{{ vendorRequest.idCardFileName ? 'Fichier fourni' : 'Non fournie' }}</p>
									</div>
								</div>
								{% if vendorRequest.idCardFileName %}
									<a href="{{ path('app_admin_vendor_request_id_card', { id: vendorRequest.id }) }}" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border text-sm text-muted-foreground hover:text-foreground hover:border-primary/40 transition-colors" target="_blank">
										<svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
										</svg>
										Télécharger
									</a>
								{% else %}
									<span class="text-xs text-muted-foreground italic">Non fournie</span>
								{% endif %}
							</div>

							{# Actions #}
							<div class="flex flex-col sm:flex-row gap-3 pt-1 border-t border-yellow-500/10">
								<form method="post" action="{{ path('app_admin_vendor_request_approve', { id: vendorRequest.id }) }}" onsubmit="return confirm('Approuver la demande de {% if user %}{{ user.firstName }} {{ user.lastName }}{% else %}cet utilisateur{% endif %} ?')">
									<input type="hidden" name="_token" value="{{ csrf_token('vendor_request_action_' ~ vendorRequest.id) }}">
									<button type="submit" class="w-full sm:w-auto flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-green-600 hover:bg-green-500 text-white text-sm font-semibold transition-colors">
										<svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
										Approuver → Devenir vendeur
									</button>
								</form>
								<form method="post" action="{{ path('app_admin_vendor_request_refuse', { id: vendorRequest.id }) }}" onsubmit="return confirm('Refuser la demande de {% if user %}{{ user.firstName }} {{ user.lastName }}{% else %}cet utilisateur{% endif %} ?')">
									<input type="hidden" name="_token" value="{{ csrf_token('vendor_request_action_' ~ vendorRequest.id) }}">
									<button type="submit" class="w-full sm:w-auto flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg border border-red-500/30 text-red-400 hover:bg-red-500/10 text-sm font-semibold transition-colors">
										<svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
										Refuser la demande
									</button>
								</form>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		</section>

		{# ════ HISTORIQUE ════ #}
		<section>
			<h2 class="text-xl font-bold text-foreground mb-4 flex items-center gap-2">
				<span class="w-2 h-2 rounded-full bg-muted-foreground inline-block"></span>
				Historique des demandes
			</h2>
			{% if processed is empty %}
				<p class="text-muted-foreground text-sm">Aucune demande traitée pour le moment.</p>
			{% else %}
				<div class="overflow-x-auto rounded-xl border border-border">
					<table class="w-full text-sm">
						<thead>
							<tr class="border-b border-border bg-secondary/30 text-left">
								<th class="px-4 py-3 font-semibold text-muted-foreground">Utilisateur</th>
								<th class="px-4 py-3 font-semibold text-muted-foreground hidden md:table-cell">Email</th>
								<th class="px-4 py-3 font-semibold text-muted-foreground hidden lg:table-cell">Motivation</th>
								<th class="px-4 py-3 font-semibold text-muted-foreground hidden lg:table-cell">Traité le</th>
								<th class="px-4 py-3 font-semibold text-muted-foreground hidden lg:table-cell">Par</th>
								<th class="px-4 py-3 font-semibold text-muted-foreground">Statut</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-border">
							{% for vendorRequest in processed %}
								{% set user = vendorRequest.user %}
								<tr class="hover:bg-secondary/20 transition-colors">
									<td class="px-4 py-3">
										<div class="flex items-center gap-3">
											<div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold shrink-0">
												{% if user %}
													{{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}{% else %}?
												{% endif %}
											</div>
											<span class="font-medium text-foreground">
												{% if user %}
													{{ user.firstName }}
													{{ user.lastName }}{% else %}—
												{% endif %}
											</span>
										</div>
									</td>
									<td class="px-4 py-3 text-muted-foreground hidden md:table-cell">{{ user ? user.email : '—' }}</td>
									<td class="px-4 py-3 hidden lg:table-cell max-w-[200px]">
										<span class="line-clamp-2 text-muted-foreground text-xs" title="{{ vendorRequest.motivation }}">
											{{ vendorRequest.motivation ?: '—' }}
										</span>
									</td>
									<td class="px-4 py-3 text-muted-foreground hidden lg:table-cell">{{ vendorRequest.processedAt ? vendorRequest.processedAt|date('d/m/Y') : '—' }}</td>
									<td class="px-4 py-3 text-muted-foreground hidden lg:table-cell">
										{% if vendorRequest.processedBy %}
											{{ vendorRequest.processedBy.firstName }}
											{{ vendorRequest.processedBy.lastName }}{% else %}—
										{% endif %}
									</td>
									<td class="px-4 py-3">
										{% if vendorRequest.status.value == 'approuve' %}
											<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-500/10 text-green-400 border border-green-500/20">
												<span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Approuvé
											</span>
										{% else %}
											<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-red-500/10 text-red-400 border border-red-500/20">
												<span class="w-1.5 h-1.5 rounded-full bg-red-400 inline-block"></span>Refusé
											</span>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</section>

	</div>
{% endblock %}
