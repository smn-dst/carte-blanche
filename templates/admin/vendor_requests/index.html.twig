{% extends 'base.html.twig' %}

{% block title %}Demandes vendeur — Administration{% endblock %}

{% block body %}
<div style="max-width: 900px; margin: 2rem auto; padding: 0 1rem; font-family: sans-serif;">

    <h1 style="font-size: 1.75rem; font-weight: bold; margin-bottom: 0.5rem;">Demandes vendeur</h1>
    <p style="color: #666; margin-bottom: 2rem;">Gérez les demandes de passage au rôle vendeur.</p>

    {% for message in app.flashes('success') %}
        <div style="background: #d1fae5; border: 1px solid #6ee7b7; padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1rem; color: #065f46;">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div style="background: #fee2e2; border: 1px solid #fca5a5; padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1rem; color: #991b1b;">
            {{ message }}
        </div>
    {% endfor %}

    {# --- Demandes en attente --- #}
    <section style="margin-bottom: 3rem;">
        <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">
            En attente
            <span style="background: #fef3c7; color: #92400e; font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 999px; margin-left: 0.5rem;">
                {{ pending|length }}
            </span>
        </h2>

        {% if pending is empty %}
            <p style="color: #888;">Aucune demande en attente.</p>
        {% else %}
            <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
                        <th style="padding: 0.6rem 0.8rem;">Utilisateur</th>
                        <th style="padding: 0.6rem 0.8rem;">Email</th>
                        <th style="padding: 0.6rem 0.8rem;">Date</th>
                        <th style="padding: 0.6rem 0.8rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for req in pending %}
                        <tr style="border-bottom: 1px solid #f3f4f6;">
                            <td style="padding: 0.7rem 0.8rem;">
                                {{ req.user.firstName }} {{ req.user.lastName }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; color: #555;">
                                {{ req.user.email }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; color: #888; white-space: nowrap;">
                                {{ req.createdAt|date('d/m/Y H:i') }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; display: flex; gap: 0.5rem;">
                                <form method="post" action="{{ path('app_admin_vendor_request_approve', {id: req.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('vendor_request_action_' ~ req.id) }}">
                                    <button type="submit"
                                        style="background: #059669; color: white; border: none; padding: 0.4rem 0.9rem; border-radius: 5px; cursor: pointer; font-size: 0.85rem;"
                                        onclick="return confirm('Approuver la demande de {{ req.user.firstName }} {{ req.user.lastName }} ?')">
                                        Approuver
                                    </button>
                                </form>
                                <form method="post" action="{{ path('app_admin_vendor_request_refuse', {id: req.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('vendor_request_action_' ~ req.id) }}">
                                    <button type="submit"
                                        style="background: #dc2626; color: white; border: none; padding: 0.4rem 0.9rem; border-radius: 5px; cursor: pointer; font-size: 0.85rem;"
                                        onclick="return confirm('Refuser la demande de {{ req.user.firstName }} {{ req.user.lastName }} ?')">
                                        Refuser
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

    {# --- Demandes traitées récentes --- #}
    <section>
        <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Traitées récemment</h2>

        {% if processed is empty %}
            <p style="color: #888;">Aucune demande traitée.</p>
        {% else %}
            <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
                        <th style="padding: 0.6rem 0.8rem;">Utilisateur</th>
                        <th style="padding: 0.6rem 0.8rem;">Email</th>
                        <th style="padding: 0.6rem 0.8rem;">Statut</th>
                        <th style="padding: 0.6rem 0.8rem;">Traité le</th>
                        <th style="padding: 0.6rem 0.8rem;">Par</th>
                    </tr>
                </thead>
                <tbody>
                    {% for req in processed %}
                        <tr style="border-bottom: 1px solid #f3f4f6;">
                            <td style="padding: 0.7rem 0.8rem;">
                                {{ req.user.firstName }} {{ req.user.lastName }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; color: #555;">
                                {{ req.user.email }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem;">
                                {% if req.status.value == 'approuve' %}
                                    <span style="background: #d1fae5; color: #065f46; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.8rem;">Approuvé</span>
                                {% else %}
                                    <span style="background: #fee2e2; color: #991b1b; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.8rem;">Refusé</span>
                                {% endif %}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; color: #888; white-space: nowrap;">
                                {{ req.processedAt|date('d/m/Y H:i') }}
                            </td>
                            <td style="padding: 0.7rem 0.8rem; color: #555;">
                                {% if req.processedBy %}
                                    {{ req.processedBy.firstName }} {{ req.processedBy.lastName }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

</div>
{% endblock %}
