<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23151515'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%236366F9'/%3E%3C/svg%3E">
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('styles/app.css') }}">
		{% endblock %}


		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body class="flex h-screen overflow-hidden bg-background text-white">
		{# Sprite SVG inline #}
		{{ source('_sprite.svg')|raw }}

		<div class="hidden lg:block">
			{{ include('Components/headers/header-desktop.html.twig') }}
		</div>
		<div class="lg:hidden">
			{{ include('Components/headers/header-mobile.html.twig') }}
		</div>

		<main class="w-full h-screen overflow-y-auto text-white relative pt-16 lg:pt-0">
			{{ include('Components/chatbot/chatbot_toggle-btn.html.twig') }}

			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<div class="fixed top-20 right-4 z-50 p-4 rounded-lg border text-sm transition-all max-w-xs
							{{ type == 'error' ? 'bg-red-500/10 border-red-500/30 text-red-400' : 'bg-green-500/10 border-green-500/30 text-green-400' }}">
						{{ message }}
					</div>
				{% endfor %}
			{% endfor %}

			{% block body %}{% endblock %}
		</main>

	</body>
</html>
