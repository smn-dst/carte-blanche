{% extends 'base.html.twig' %}

{% block title %}Favoris{% endblock %}

{% block body %}
    <div class="flex flex-col flex-1 min-h-0">
        {% for type, message in app.flashes %}
            <div class="alert alert-{{ type }}" role="alert">
                {{ message | join(', ') }}
            </div>
        {% endfor %}

        {% set total = restaurants|length %}
        {% include 'Components/headers/page-header.html.twig' with {
            title: 'Mes Favoris',
            description: total ~ ' enchère' ~ (total > 1 ? 's' : '') ~ ' en favori' ~ (total > 1 ? 's' : '')
        } %}

        {{ include('favorites/_search.html.twig') }}

        <div class="flex-1 min-h-0">
            {{ include('favorites/_favoris.html.twig', { restaurants: restaurants }) }}
        </div>
    </div>
{% endblock %}
