{% set type = type|default('text') %}

<input
    type="{{ type }}"
    name="{{ name|default('') }}"
    value="{{ value|default('') }}"

    {% if type != 'range' %}
        placeholder="{{ label|default('') }}"
        autocomplete="off"
    {% endif %}

    {% if type == 'range' %}
        min="{{ min|default(0) }}"
        max="{{ max|default(0) }}"
        step="{{ step|default(1000) }}"
    {% endif %}
    
    onchange="this.form.submit()"
    class="{{ class|default('') }}"
>