{% set cart_count = cart_item_count() %}
<div data-controller="mobile-menu" class="lg:hidden">
	{# Barre supérieure #}
	<header class="fixed top-0 inset-x-0 z-50 min-h-[5rem] py-3 bg-background/50 backdrop-blur-xl flex items-center box-border justify-between px-5 border-b border-border text-white">
		<button type="button" class="p-3 -m-3 touch-manipulation cursor-pointer rounded-lg hover:bg-secondary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background" data-mobile-menu-target="openButton" data-action="click->mobile-menu#open" aria-expanded="false" aria-controls="mobile-nav-panel" aria-label="Ouvrir le menu de navigation">
			<svg class="size-7" aria-hidden="true"><use href="#icon-menu"/></svg>
		</button>

		<a href="{{ path('app_home') }}" class="flex items-baseline gap-2 py-2 min-w-0 cursor-pointer rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Carte blanche accueil">
			<span class="text-2xl font-bold truncate">Carte blanche</span>
			<span class="w-2 h-2 rounded-full bg-primary flex-shrink-0" aria-hidden="true"></span>
		</a>

		<nav class="flex items-center gap-1 shrink-0" aria-label="Actions rapides">
			<a href="{{ path('app_cart') }}" class="relative p-3 -m-3 touch-manipulation inline-flex items-center justify-center cursor-pointer rounded-lg hover:bg-secondary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Panier{% if cart_count > 0 %} ({{ cart_count }} article{{ cart_count > 1 ? 's' : '' }}){% endif %}">
				<span class="relative inline-flex">
					<svg class="size-7" aria-hidden="true"><use href="#icon-shopping-cart"/></svg>
					{% if cart_count > 0 %}
						<span class="absolute -top-0.5 -right-0.5 min-w-[1.125rem] h-[1.125rem] px-0.5 flex items-center justify-center rounded-full bg-primary text-[10px] font-bold text-primary-foreground tabular-nums leading-none">{{ cart_count }}</span>
					{% endif %}
				</span>
			</a>
			{% if is_granted('IS_AUTHENTICATED_FULLY') %}
				<a href="{{ path('app_logout') }}" class="p-3 -m-3 touch-manipulation inline-flex cursor-pointer rounded-lg hover:bg-secondary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Déconnexion">
					<svg class="size-7" aria-hidden="true"><use href="#icon-log-out"/></svg>
				</a>
			{% else %}
				<a href="{{ path('app_login') }}" class="p-3 -m-3 touch-manipulation inline-flex cursor-pointer rounded-lg hover:bg-secondary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Connexion">
					<svg class="size-7" aria-hidden="true"><use href="#icon-log-in"/></svg>
				</a>
			{% endif %}
		</nav>
	</header>

	{# Voile #}
	<div data-mobile-menu-target="backdrop" data-action="click->mobile-menu#close" class="fixed inset-0 z-[55] bg-black/65 opacity-0 pointer-events-none transition-opacity duration-200 ease-out lg:hidden" aria-hidden="true" tabindex="-1"></div>

	{# Tiroir #}
	<div id="mobile-nav-panel" data-mobile-menu-target="panel" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Menu de navigation" class="fixed top-0 left-0 z-[56] h-[100dvh] w-full max-w-[min(100vw,20rem)] -translate-x-full flex flex-col bg-sidebar border-r border-sidebar-border shadow-2xl transition-transform duration-200 ease-out lg:hidden">
		<div class="flex-shrink-0 flex items-center justify-between gap-3 p-4 border-b border-sidebar-border">
			<a href="{{ path('app_home') }}" class="flex items-baseline gap-2 min-w-0 cursor-pointer rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" data-action="click->mobile-menu#navigateAway">
				<span class="text-lg font-bold tracking-tight truncate text-foreground">Carte blanche</span>
				<span class="w-2 h-2 rounded-full bg-primary flex-shrink-0" aria-hidden="true"></span>
			</a>
			<button type="button" data-mobile-menu-target="closeButton" data-action="click->mobile-menu#close" class="cursor-pointer p-2 rounded-lg hover:bg-secondary text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Fermer le menu">
				<svg class="size-6" aria-hidden="true"><use href="#icon-x"/></svg>
			</button>
		</div>

		<div class="flex-1 min-h-0 overflow-y-auto overscroll-y-contain p-4 flex flex-col gap-6" data-action="click->mobile-menu#navigateAway">
			{% include 'Components/headers/_primary_nav.html.twig' with { nav_aria: 'Navigation principale' } %}

			<div class="pt-2 border-t border-sidebar-border">
				<a href="{{ path('app_cart') }}" class="relative w-full flex justify-start items-center gap-3 px-4 py-3 border border-border rounded-lg hover:bg-secondary hover:border-primary/50 transition-all cursor-pointer text-foreground" aria-label="Panier{% if cart_count > 0 %} ({{ cart_count }} article{{ cart_count > 1 ? 's' : '' }}){% endif %}">
					<span class="relative inline-flex shrink-0">
						<svg class="size-4" aria-hidden="true"><use href="#icon-shopping-cart"/></svg>
						{% if cart_count > 0 %}
							<span class="absolute -top-2 -right-2 min-w-[1.125rem] h-[1.125rem] px-0.5 flex items-center justify-center rounded-full bg-primary text-[10px] font-bold text-primary-foreground tabular-nums leading-none">{{ cart_count }}</span>
						{% endif %}
					</span>
					<span class="text-sm font-medium">Panier</span>
				</a>
			</div>
		</div>

		<div class="flex-shrink-0 p-4 border-t border-sidebar-border space-y-3 bg-sidebar">
			{% if is_granted('IS_AUTHENTICATED_FULLY') %}
				<a href="{{ path('app_logout') }}" class="w-full flex justify-start items-center gap-3 px-4 py-3 border border-border rounded-lg hover:bg-secondary hover:border-primary/50 transition-all cursor-pointer text-foreground text-sm" data-action="click->mobile-menu#navigateAway" aria-label="Déconnexion">
					<svg class="size-4 shrink-0" aria-hidden="true"><use href="#icon-log-out"/></svg>
					<span>Déconnexion</span>
				</a>
			{% else %}
				<a href="{{ path('app_login') }}" class="w-full flex justify-start items-center gap-3 px-4 py-3 border border-border rounded-lg hover:bg-secondary hover:border-primary/50 transition-all cursor-pointer text-foreground text-sm" data-action="click->mobile-menu#navigateAway" aria-label="Connexion">
					<svg class="size-4 shrink-0" aria-hidden="true"><use href="#icon-log-in"/></svg>
					<span>Connexion</span>
				</a>
			{% endif %}

			{# ── Liens légaux ── #}
			<div class="pt-1 space-y-1">
				<div class="flex flex-wrap gap-x-3 gap-y-1">
					<a href="{{ path('app_rgpd') }}" class="text-[11px] text-muted-foreground/60 hover:text-muted-foreground transition-colors" data-action="click->mobile-menu#navigateAway">Confidentialité</a>
					<a href="{{ path('app_cgv') }}" class="text-[11px] text-muted-foreground/60 hover:text-muted-foreground transition-colors" data-action="click->mobile-menu#navigateAway">CGV</a>
					<a href="{{ path('app_cgu') }}" class="text-[11px] text-muted-foreground/60 hover:text-muted-foreground transition-colors" data-action="click->mobile-menu#navigateAway">CGU</a>
				</div>
				<p class="text-[11px] text-muted-foreground/40">© 2026 Carte Blanche</p>
			</div>
		</div>
	</div>
</div>
