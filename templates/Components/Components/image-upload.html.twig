{#
  Variables attendues :
    - form          : FormView du step 4 (ou du formulaire mono-page)
    - restaurant    : entité Restaurant (optionnel, pour afficher les images existantes)
#}

<div class="rounded-xl border border-border bg-secondary/20 p-6 space-y-4">
    <h2 class="text-lg font-semibold">Images</h2>
    <p class="text-sm text-muted-foreground">Formats acceptés : JPEG, PNG, WebP — 5 Mo max par image.</p>

    {% if restaurant is defined and restaurant.images|length > 0 %}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {% for image in restaurant.images %}
                {% if image.fileName %}
                    <div class="relative group rounded-lg overflow-hidden border border-border">
                        <img src="{{ asset('uploads/restaurants/' ~ image.fileName) }}"
                             alt="Image {{ loop.index }}"
                             class="w-full h-36 object-cover">
                        <div class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button type="submit"
                                    form="delete-image-{{ image.id }}"
                                    onclick="return confirm('Supprimer cette image ?')"
                                    class="rounded-md bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition-colors">
                                Supprimer
                            </button>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    <div data-image-upload-wrapper class="space-y-3">
        {{ form_label(form.uploadedImages, null, {'label_attr': {'class': 'text-sm text-muted-foreground'}}) }}

        <div data-image-upload-group
             data-input-name="{{ form.vars.name }}[uploadedImages][]"
             data-input-id-prefix="{{ form.uploadedImages.vars.id }}"
             class="space-y-3">
            <div data-image-upload-row class="rounded-lg border border-border/70 bg-background/30 p-3">
                <div class="flex flex-col gap-2 md:flex-row md:items-center">
                    <input type="file"
                           id="{{ form.uploadedImages.vars.id }}_0"
                           name="{{ form.vars.name }}[uploadedImages][]"
                           accept="image/jpeg,image/png,image/webp"
                           class="block w-full text-sm text-muted-foreground file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary/80 cursor-pointer">
                    <button type="button"
                            data-remove-image-input
                            class="hidden rounded-md border border-red-500/40 bg-red-500/10 px-3 py-2 text-xs text-red-300 hover:bg-red-500/20 transition-colors">
                        Supprimer
                    </button>
                </div>
                <div data-preview class="mt-2 hidden">
                    <img src="" alt="Aperçu" class="h-20 w-20 object-cover rounded border border-border">
                </div>
            </div>
        </div>

        <button type="button"
                data-add-image-input
                class="inline-flex items-center rounded-md border border-primary/40 bg-primary/10 px-3 py-2 text-sm text-primary hover:bg-primary hover:text-white transition-colors">
            + Ajouter une autre image
        </button>

        {% do form.uploadedImages.setRendered %}
        <div class="text-red-400 text-xs mt-1">{{ form_errors(form.uploadedImages) }}</div>
        <p class="text-xs text-muted-foreground">Ajoutez les images une par une avec le bouton, ou utilisez Ctrl/Cmd dans le sélecteur.</p>
    </div>
</div>

<script>
(function () {
    const wrapper = document.querySelector('[data-image-upload-wrapper]');
    if (!wrapper) return;

    const group = wrapper.querySelector('[data-image-upload-group]');
    const addBtn = wrapper.querySelector('[data-add-image-input]');
    const inputName = group.dataset.inputName;
    const idPrefix = group.dataset.inputIdPrefix;

    function attachRowListeners(row) {
        const fileInput = row.querySelector('input[type="file"]');
        const removeBtn = row.querySelector('[data-remove-image-input]');
        const preview = row.querySelector('[data-preview]');
        const previewImg = preview ? preview.querySelector('img') : null;

        fileInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file && previewImg) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            } else if (previewImg) {
                preview.classList.add('hidden');
                previewImg.src = '';
            }
        });

        removeBtn.addEventListener('click', function () {
            row.remove();
        });
    }

    // Init first row
    attachRowListeners(group.querySelector('[data-image-upload-row]'));

    addBtn.addEventListener('click', function () {
        const rows = group.querySelectorAll('[data-image-upload-row]');
        const idx = rows.length;

        const row = document.createElement('div');
        row.setAttribute('data-image-upload-row', '');
        row.className = 'rounded-lg border border-border/70 bg-background/30 p-3';
        row.innerHTML = `
            <div class="flex flex-col gap-2 md:flex-row md:items-center">
                <input type="file"
                       id="${idPrefix}_${idx}"
                       name="${inputName}"
                       accept="image/jpeg,image/png,image/webp"
                       class="block w-full text-sm text-muted-foreground file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary/80 cursor-pointer">
                <button type="button"
                        data-remove-image-input
                        class="rounded-md border border-red-500/40 bg-red-500/10 px-3 py-2 text-xs text-red-300 hover:bg-red-500/20 transition-colors">
                    Supprimer
                </button>
            </div>
            <div data-preview class="mt-2 hidden">
                <img src="" alt="Aperçu" class="h-20 w-20 object-cover rounded border border-border">
            </div>
        `;

        group.appendChild(row);
        attachRowListeners(row);
    });

    // Show remove button on first row only after a second row exists
    const observer = new MutationObserver(function () {
        const rows = group.querySelectorAll('[data-image-upload-row]');
        rows.forEach(function (r, i) {
            const btn = r.querySelector('[data-remove-image-input]');
            if (!btn) return;
            btn.classList.toggle('hidden', rows.length === 1);
        });
    });
    observer.observe(group, { childList: true });
}());
</script>
