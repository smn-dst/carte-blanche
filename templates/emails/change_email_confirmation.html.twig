<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
	</head>
	<body style="margin:0;padding:0;background-color:#0a0a0a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
		<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0a0a0a;padding:40px 20px;">
			<tr>
				<td align="center">
					<table width="600" cellpadding="0" cellspacing="0" style="background-color:#151515;border-radius:12px;border:1px solid #2a2a2a;max-width:600px;">
						<tr>
							<td style="padding:40px 40px 20px;text-align:center;border-bottom:1px solid #2a2a2a;">
								<h1 style="color:#6366F9;font-size:24px;margin:0;letter-spacing:-0.02em;">Carte Blanche</h1>
								<p style="color:#666;font-size:11px;margin:8px 0 0;text-transform:uppercase;letter-spacing:0.12em;">Changement d'email</p>
							</td>
						</tr>
						<tr>
							<td style="padding:40px;">
								<h2 style="color:#ffffff;font-size:22px;text-align:center;margin:0 0 12px;font-weight:700;">
									Confirmez votre nouvelle adresse
								</h2>
								<p style="color:#a1a1a1;text-align:center;margin:0 0 28px;font-size:15px;line-height:1.55;">
									{% if firstName %}
										Bonjour {{ firstName }},<br>
									{% else %}
										Bonjour,<br>
									{% endif %}
									cliquez sur le bouton ci-dessous pour confirmer votre nouvelle adresse email. Ce lien est valable une heure.
								</p>
								<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
									<tr>
										<td align="center">
											<a href="{{ confirmUrl }}" style="display:inline-block;background-color:#6366F9;color:#ffffff;padding:14px 36px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;">
												Confirmer mon email
											</a>
										</td>
									</tr>
								</table>
								<p style="color:#525252;font-size:12px;text-align:center;margin:24px 0 0;line-height:1.5;">
									Si vous n’êtes pas à l’origine de cette demande, ignorez cet e-mail.
								</p>
							</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>
