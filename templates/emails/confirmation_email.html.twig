<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
	</head>
	<body style="margin:0;padding:0;background-color:#0a0a0a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">

		<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0a0a0a;padding:40px 20px;">
			<tr>
				<td align="center">
					<table width="600" cellpadding="0" cellspacing="0" style="background-color:#151515;border-radius:12px;border:1px solid #2a2a2a;max-width:600px;">

						<tr>
							<td style="padding:40px 40px 20px;text-align:center;border-bottom:1px solid #2a2a2a;">
								<h1 style="color:#6366F9;font-size:24px;margin:0;letter-spacing:-0.02em;">Carte Blanche</h1>
								<p style="color:#666;font-size:11px;margin:8px 0 0;text-transform:uppercase;letter-spacing:0.12em;">Plateforme d'enchères premium</p>
							</td>
						</tr>

						<tr>
							<td style="padding:40px;">
								<div style="text-align:center;margin-bottom:28px;">
									<div style="width:4px;height:40px;background:linear-gradient(180deg,#6366F9,#6366F9 40%,transparent);border-radius:2px;margin:0 auto;"></div>
								</div>

								<h2 style="color:#ffffff;font-size:22px;text-align:center;margin:0 0 12px;font-weight:700;">
									Confirmez votre adresse email
								</h2>
								<p style="color:#a1a1a1;text-align:center;margin:0 0 28px;font-size:15px;line-height:1.55;">
									{% if user.firstName %}
										Bonjour
										{{ user.firstName }},<br>
									{% else %}
										Bonjour,<br>
									{% endif %}
									merci de rejoindre Carte Blanche. Cliquez sur le bouton ci-dessous pour valider votre compte et finaliser votre inscription.
								</p>

								<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
									<tr>
										<td align="center">
											<a href="{{ signedUrl|raw }}" style="display:inline-block;background-color:#6366F9;color:#ffffff;padding:14px 36px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;">
												Confirmer mon adresse email
											</a>
										</td>
									</tr>
								</table>

								<p style="color:#737373;font-size:12px;text-align:center;margin:0 0 20px;line-height:1.5;">
									Ce lien expire dans
									{{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
								</p>

								<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#1a1a1a;border-radius:8px;border:1px solid #2a2a2a;">
									<tr>
										<td style="padding:16px 20px;">
											<p style="color:#737373;font-size:11px;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.06em;">Si le bouton ne fonctionne pas</p>
											<p style="color:#a1a1a1;font-size:12px;margin:0;word-break:break-all;">
												<a href="{{ signedUrl|raw }}" style="color:#6366F9;">{{ signedUrl|raw }}</a>
											</p>
										</td>
									</tr>
								</table>

								<p style="color:#525252;font-size:12px;text-align:center;margin:24px 0 0;line-height:1.5;">
									Si vous n'avez pas créé de compte sur Carte Blanche, vous pouvez ignorer cet email.
								</p>
							</td>
						</tr>

						<tr>
							<td style="padding:20px 40px;border-top:1px solid #2a2a2a;text-align:center;">
								<p style="color:#666;font-size:11px;margin:0;">© 2026 Carte Blanche — Tous droits réservés</p>
							</td>
						</tr>

					</table>
				</td>
			</tr>
		</table>

	</body>
</html>
