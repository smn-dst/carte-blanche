{% extends 'base.html.twig' %}

{% block title %}Devenir vendeur — Carte Blanche{% endblock %}

{% block body %}
<div class="min-h-screen flex items-start justify-center px-4 py-12">
<div class="w-full max-w-2xl">

    {# ── En-tête ── #}
    <div class="text-center mb-10">
        <p class="text-xs text-primary uppercase tracking-widest font-semibold mb-2">Espace vendeur</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-foreground">Devenir vendeur</h1>
        <p class="text-muted-foreground mt-2">Complétez les étapes ci-dessous pour soumettre votre candidature.</p>
    </div>

    {# ── Indicateur d'étapes ── #}
    <div class="flex items-center gap-0 mb-10" id="step-indicator">
        {% for i in 1..3 %}
            <div class="flex items-center {{ not loop.last ? 'flex-1' : '' }}">
                <div class="step-dot relative flex items-center justify-center w-9 h-9 rounded-full border-2 text-sm font-bold transition-all duration-300
                    {{ loop.first ? 'border-primary bg-primary text-white' : 'border-border bg-background text-muted-foreground' }}"
                    data-step="{{ i }}">
                    <span class="step-number">{{ i }}</span>
                    <svg class="step-check hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                {% if not loop.last %}
                    <div class="step-line flex-1 h-0.5 bg-border transition-all duration-300" data-after-step="{{ i }}"></div>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {# ── Flashes ── #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 p-4 rounded-lg border text-sm
                {{ type == 'success' ? 'bg-green-500/10 border-green-500/30 text-green-400' : 'bg-red-500/10 border-red-500/30 text-red-400' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# ── Formulaire unique (toutes les étapes dedans) ── #}
    <form method="post"
          action="{{ path('app_vendor_request_create') }}"
          enctype="multipart/form-data"
          id="vendor-wizard-form"
          novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('vendor_request') }}">

        {# ════ ÉTAPE 1 — Motivation ════ #}
        <div class="wizard-step" data-step="1">
            <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-foreground">Votre projet</h2>
                    <p class="text-sm text-muted-foreground mt-1">Expliquez-nous pourquoi vous souhaitez devenir vendeur sur Carte Blanche.</p>
                </div>

                <div class="space-y-4">
                    <div>
                        <label for="motivation" class="block text-sm font-medium text-foreground mb-2">
                            Votre motivation <span class="text-red-400">*</span>
                        </label>
                        <textarea id="motivation"
                                  name="motivation"
                                  rows="6"
                                  minlength="50"
                                  required
                                  placeholder="Décrivez votre expérience dans la restauration, votre projet de vente, vos motivations à rejoindre la plateforme…"
                                  class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm resize-none"></textarea>
                        <p class="text-xs text-muted-foreground mt-1.5" id="char-count">Minimum 50 caractères</p>
                    </div>
                </div>

                <div class="flex justify-end pt-2">
                    <button type="button"
                            class="btn-next flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition-colors"
                            data-next="2">
                        Étape suivante
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7 7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        {# ════ ÉTAPE 2 — Pièce d'identité ════ #}
        <div class="wizard-step hidden" data-step="2">
            <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-foreground">Vérification d'identité</h2>
                    <p class="text-sm text-muted-foreground mt-1">Uploadez une photo ou scan de votre pièce d'identité (carte nationale ou passeport).</p>
                </div>

                <div class="space-y-4">
                    {# Zone de drop visuelle #}
                    <label for="id_card"
                           class="flex flex-col items-center justify-center gap-3 w-full h-40 rounded-xl border-2 border-dashed border-border bg-background/50 cursor-pointer hover:border-primary/50 hover:bg-primary/5 transition-all"
                           id="id-card-label">
                        <svg class="size-10 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
                        </svg>
                        <div class="text-center">
                            <p class="text-sm font-medium text-foreground" id="id-card-name">Cliquez pour sélectionner un fichier</p>
                            <p class="text-xs text-muted-foreground mt-0.5">JPG, PNG, WebP ou PDF — 5 Mo max</p>
                        </div>
                        <input type="file"
                               id="id_card"
                               name="id_card"
                               accept="image/jpeg,image/png,image/webp,application/pdf"
                               class="sr-only"
                               required>
                    </label>

                    <div class="flex items-start gap-3 p-4 rounded-lg border border-border bg-secondary/10 text-sm text-muted-foreground">
                        <svg class="size-4 shrink-0 mt-0.5 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
                        </svg>
                        Votre document est stocké de façon sécurisée et n'est visible que par l'équipe Carte Blanche. Il ne sera jamais partagé.
                    </div>
                </div>

                <div class="flex items-center justify-between pt-2">
                    <button type="button"
                            class="btn-prev flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border text-muted-foreground hover:text-foreground text-sm font-medium transition-colors"
                            data-prev="1">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7-7 7 7 7"/>
                        </svg>
                        Retour
                    </button>
                    <button type="button"
                            class="btn-next flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition-colors"
                            data-next="3">
                        Étape suivante
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7 7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        {# ════ ÉTAPE 3 — Récapitulatif & envoi ════ #}
        <div class="wizard-step hidden" data-step="3">
            <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-foreground">Récapitulatif</h2>
                    <p class="text-sm text-muted-foreground mt-1">Vérifiez vos informations avant d'envoyer votre demande.</p>
                </div>

                <div class="space-y-4">
                    {# Résumé motivation #}
                    <div class="rounded-lg border border-border bg-background/50 p-4">
                        <p class="text-xs text-primary uppercase tracking-wider font-semibold mb-2">Votre motivation</p>
                        <p class="text-sm text-foreground italic" id="recap-motivation">—</p>
                    </div>

                    {# Résumé pièce d'identité #}
                    <div class="rounded-lg border border-border bg-background/50 p-4 flex items-center gap-3">
                        <svg class="size-8 text-muted-foreground shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
                        </svg>
                        <div>
                            <p class="text-xs text-primary uppercase tracking-wider font-semibold mb-0.5">Pièce d'identité</p>
                            <p class="text-sm text-foreground" id="recap-id-card">Aucun fichier sélectionné</p>
                        </div>
                    </div>
                </div>

                <div class="rounded-lg border border-primary/20 bg-primary/5 p-4 text-sm text-muted-foreground">
                    En soumettant cette demande, vous certifiez que les informations fournies sont exactes. Notre équipe examinera votre candidature sous 48h et vous contactera par email.
                </div>

                <div class="flex items-center justify-between pt-2">
                    <button type="button"
                            class="btn-prev flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border text-muted-foreground hover:text-foreground text-sm font-medium transition-colors"
                            data-prev="2">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7-7 7 7 7"/>
                        </svg>
                        Retour
                    </button>
                    <button type="submit"
                            class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-green-600 hover:bg-green-500 text-white text-sm font-semibold transition-colors">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
                        </svg>
                        Envoyer ma candidature
                    </button>
                </div>
            </div>
        </div>

    </form>

</div>
</div>

<script>
(function () {
    let currentStep = 1;
    const totalSteps = 3;

    function goToStep(step) {
        // Cacher toutes les étapes
        document.querySelectorAll('.wizard-step').forEach(el => el.classList.add('hidden'));
        // Montrer l'étape cible
        document.querySelector(`.wizard-step[data-step="${step}"]`).classList.remove('hidden');

        // Mettre à jour les indicateurs
        document.querySelectorAll('.step-dot').forEach(dot => {
            const n = parseInt(dot.dataset.step);
            dot.classList.remove('border-primary', 'bg-primary', 'text-white', 'border-green-500', 'bg-green-600', 'border-border', 'text-muted-foreground');
            const num = dot.querySelector('.step-number');
            const chk = dot.querySelector('.step-check');
            if (n < step) {
                dot.classList.add('border-green-500', 'bg-green-600', 'text-white');
                num.classList.add('hidden');
                chk.classList.remove('hidden');
            } else if (n === step) {
                dot.classList.add('border-primary', 'bg-primary', 'text-white');
                num.classList.remove('hidden');
                chk.classList.add('hidden');
            } else {
                dot.classList.add('border-border', 'text-muted-foreground');
                num.classList.remove('hidden');
                chk.classList.add('hidden');
            }
        });

        // Mettre à jour les lignes de connexion
        document.querySelectorAll('.step-line').forEach(line => {
            const after = parseInt(line.dataset.afterStep);
            if (after < step) {
                line.classList.remove('bg-border');
                line.classList.add('bg-green-500');
            } else {
                line.classList.remove('bg-green-500');
                line.classList.add('bg-border');
            }
        });

        currentStep = step;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Boutons suivant
    document.querySelectorAll('.btn-next').forEach(btn => {
        btn.addEventListener('click', () => {
            const next = parseInt(btn.dataset.next);

            // Validation étape 1
            if (currentStep === 1) {
                const motivation = document.getElementById('motivation').value.trim();
                if (motivation.length < 50) {
                    document.getElementById('char-count').classList.add('text-red-400');
                    document.getElementById('char-count').textContent = `Minimum 50 caractères (${motivation.length}/50)`;
                    return;
                }
            }

            // Validation étape 2
            if (currentStep === 2) {
                const file = document.getElementById('id_card').files[0];
                if (!file) {
                    document.getElementById('id-card-name').textContent = 'Veuillez sélectionner un fichier';
                    document.getElementById('id-card-name').classList.add('text-red-400');
                    return;
                }
            }

            // Mise à jour du récapitulatif avant l'étape 3
            if (next === 3) {
                const motivation = document.getElementById('motivation').value.trim();
                const maxLen = 200;
                document.getElementById('recap-motivation').textContent =
                    motivation.length > maxLen ? motivation.substring(0, maxLen) + '…' : motivation;

                const file = document.getElementById('id_card').files[0];
                document.getElementById('recap-id-card').textContent = file ? file.name : 'Aucun fichier';
            }

            goToStep(next);
        });
    });

    // Boutons précédent
    document.querySelectorAll('.btn-prev').forEach(btn => {
        btn.addEventListener('click', () => goToStep(parseInt(btn.dataset.prev)));
    });

    // Compteur de caractères motivation
    const motivationField = document.getElementById('motivation');
    const charCount = document.getElementById('char-count');
    motivationField.addEventListener('input', () => {
        const len = motivationField.value.trim().length;
        charCount.classList.toggle('text-red-400', len < 50);
        charCount.classList.toggle('text-green-400', len >= 50);
        charCount.textContent = len < 50 ? `Minimum 50 caractères (${len}/50)` : `✓ ${len} caractères`;
    });

    // Affichage nom fichier pièce d'identité
    document.getElementById('id_card').addEventListener('change', function () {
        const file = this.files[0];
        const nameEl = document.getElementById('id-card-name');
        if (file) {
            nameEl.textContent = file.name;
            nameEl.classList.remove('text-red-400');
            nameEl.classList.add('text-green-400');
        }
    });
})();
</script>
{% endblock %}
