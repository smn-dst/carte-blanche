parameters:
    level: 8
    paths:
        - src/
        - tests/
    # Vendor neuron-ai absent ou non analysé : définition minimale pour les agents qui étendent NeuronAI\Agent
    scanFiles:
        - phpstan-stubs/NeuronAI/Agent.php
    excludePaths:
        - .php-cs-fixer.dist.php
    ignoreErrors:
        # Doctrine assigne l'id après persist()
        - identifier: property.unusedType
          path: src/Entity/*.php
